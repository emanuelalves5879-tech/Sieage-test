				<ProtectedString name="Source"><![CDATA[-- ============================================
-- MÓDULO BASE: Sistema de vida do castelo
-- ============================================

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Base = {}

-- Referência ao GameConfig (sistema de vida)
local GameConfig = ReplicatedStorage:WaitForChild("GameConfig")

-- ============================================
-- FUNÇÃO: Causa dano ao castelo
-- ============================================
function Base.TakeDamage(dano)
	local config = require(GameConfig)
	config.PerderVida(dano)
end

-- ============================================
-- FUNÇÃO: Retorna a vida atual do castelo
-- ============================================
function Base.GetVida()
	local config = require(GameConfig)
	return config.GetVida()
end

return Base
]]></ProtectedString>
