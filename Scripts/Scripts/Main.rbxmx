			<ProtectedString name="Source"><![CDATA[-- ============================================
-- SCRIPT PRINCIPAL: Controla as ondas de zumbis
-- ============================================

print("[Main] Script iniciado!")

-- Carrega o módulo que gerencia os zumbis
local zumbi = require(script.Mob)
print("[Main] Módulo Mob carregado!")

-- Referência ao mapa do jogo
local mapa = workspace:WaitForChild("cenario")
print("[Main] Mapa encontrado: " .. mapa.Name)

-- Espera o mapa estar completamente carregado
task.wait(2)

-- Verifica se o mapa tem os waypoints necessários
local waypoints = mapa:FindFirstChild("waypoints")
local start = mapa:FindFirstChild("Start")

if not waypoints then
	warn("ERRO: waypoints não encontrado no mapa!")
	return
end

if not start then
	warn("ERRO: Start não encontrado no mapa!")
	return
end

print("[Main] Waypoints: " .. waypoints.Name .. ", Start: " .. start.Name)
print("=== MAPA PRONTO! Iniciando ondas... ===")

-- ============================================
-- LOOP PRINCIPAL: 7 ondas de zumbis
-- ============================================
for onda = 1, 7 do
	print("=== ONDA", onda, "INICIANDO ===")
	
	-- Calcula quantos zumbis e qual velocidade para esta onda
	local quantidade, velocidade = zumbi.CalcularOnda(onda)
	
	-- Calcula multiplicador de HP do Dark Skeleton (a partir da onda 4: +5 HP por onda)
	local skeletonVidaMult = zumbi.CalcularSkeletonHP(onda)
	
	print("Spawning: " .. quantidade .. " zumbis com " .. (velocidade * 100) .. "% de velocidade" .. (skeletonVidaMult > 1 and " e " .. string.format("%.0f", 30 * skeletonVidaMult) .. " HP" or ""))
	
	-- Spawna a onda de Dark Skeletons
	zumbi.SpawnWave("Dark Skeletons", mapa, quantidade, velocidade, skeletonVidaMult, onda)
	
	-- A partir da onda 4, spawna Golems também
	if onda >= 4 then
		-- Tempo de espera entre Dark Skeletons e Golems: 2s (ondas 4-5), 1.75s (onda 6+)
		local tempoEspera = onda >= 6 and 1.75 or 2
		task.wait(tempoEspera)
		local golemQuantidade = onda - 3 -- Onda 4=1, Onda 5=2, Onda 6=3
		
		-- Calcula multiplicadores do Golem (+30% velocidade, +10% vida por onda)
		local golemVelMult, golemVidaMult = zumbi.CalcularGolemStats(onda)
		local golemVelocidade = velocidade * 0.5 * golemVelMult -- Base: metade do Dark Skeleton, depois +30% por onda
		
		print("Spawning: " .. golemQuantidade .. " Golems (Vel: " .. string.format("%.0f%%", golemVelMult * 100) .. ", Vida: " .. string.format("%.0f%%", golemVidaMult * 100) .. ")")
		zumbi.SpawnWave("Golem", mapa, golemQuantidade, golemVelocidade, golemVidaMult, onda)
	end
	
	-- Espera todos os zumbis morrerem ou chegarem ao final
	repeat
		task.wait(1)
	until zumbi.ContarVivos() == 0
	
	print("=== ONDA", onda, "FINALIZADA ===")
	task.wait(2)  -- Pausa de 2 segundos entre ondas
end

print("=== TODAS AS ONDAS COMPLETAS! ===")]]></ProtectedString>
